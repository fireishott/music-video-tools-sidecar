##### LIDARR EXTENDED SCRIPTS SETTINGS #####

##### LIDARR API SETTINGS
LidarrUrl="http://localhost:8686"
LidarrApiKey="your-api-key-here"

##### PATHS
downloadPath="/config/extended/downloads"
videoPath="/mnt/musicvideos"

##### SCRIPT ENABLEMENT
enableVideo="true"

##### VIDEO SCRIPT SETTINGS - CORE
videoScriptInterval="15m"
videoContainer="mkv"
youtubeCookiesFile="/config/cookies.txt"
youtubeSubtitleLanguage="en"
videoDownloadTag=""

# ==============================================================================
# METADATA ENHANCEMENT SETTINGS
# ==============================================================================

# Stats update interval in days (default: 7)
# How often to refresh YouTube view counts and likes
statsUpdateInterval="7"

# Force update all stats on next run (default: false)
# Set to "true" once to refresh everything, then set back to false
forceStatsUpdate="false"

# Update stats on existing videos when found (default: true)
# When scanning existing library, should we check if stats need update?
updateStatsOnExisting="true"

# MusicBrainz rate limiting in seconds (default: 1)
# Be nice to MusicBrainz servers - increase if you're getting blocked
musicbrainzRateLimit="1"

# Rich NFO threshold (default: 7)
# Minimum number of fields to consider an NFO "rich" (out of 10)
# Lower = more aggressive upgrades, Higher = fewer upgrades
richNfoThreshold="7"

# Enable/disable specific metadata sources (all default to true)
enableMusicBrainz="true"        # Album info, ISRC, MBIDs, genres
enableYouTubeStats="true"       # Views, likes, channel info
enableFeaturedArtists="true"    # Extract and add as actors
enableTechnicalMetadata="true"  # BPM, musical key, composer, producer

# ==============================================================================
# SEARCH SETTINGS
# ==============================================================================
strictArtistFiltering="true"
filterLyricVideos="true"
filterCompilations="true"
maxSearchResults="40"
ytdlpRateLimit="2"

# ==============================================================================
# DOWNLOAD SETTINGS
# ==============================================================================
downloadDelay="2"
maxRetries="3"
minimumVideoHeight="360"

# ==============================================================================
# ADVANCED YT-DLP
# ==============================================================================
# Note: --no-write-annotations removed as it's deprecated
ytdlpExtraArgs="--no-mtime --geo-bypass --no-write-info-json --no-write-description"
ytdlpCacheDir="/config/extended/cache/ytdlp"

# ==============================================================================
# RESCAN BEHAVIOR
# ==============================================================================
alwaysRescanArtists="true"
ignoreCompletionLogs="true"
