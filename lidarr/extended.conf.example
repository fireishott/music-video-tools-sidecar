##### LIDARR EXTENDED SCRIPTS SETTINGS #####

##### LIDARR API SETTINGS
LidarrUrl="http://localhost:8686"
LidarrApiKey="your-api-key-here"

##### PATHS
downloadPath="/config/extended/downloads"
videoPath="/mnt/musicvideos"

##### SCRIPT ENABLEMENT
enableVideo="true"

##### VIDEO SCRIPT SETTINGS - CORE
videoScriptInterval="5m"
videoContainer="mkv"
youtubeCookiesFile="/config/cookies.txt"
youtubeSubtitleLanguage="en"
videoDownloadTag=""

# Quality control
minimumVideoHeight="360"

##### METADATA ENHANCEMENT SETTINGS
statsUpdateInterval="7"
forceStatsUpdate="false"
musicbrainzRateLimit="1"
updateStatsOnExisting="true"
enableMusicBrainz="true"
enableYouTubeStats="true"
enableFeaturedArtists="true"
enableTechnicalMetadata="true"
enableIdRecovery="true"

# AUDIO-ONLY FILTERING SETTINGS
filterAudioOnly="true"
minVideoDimension="480"
# Minimum duration in seconds (default: 60)
minDuration="60"
# Maximum duration in seconds (default: 600 = 10 minutes)
maxDuration="600"

# Search settings
strictArtistFiltering="true"
filterLyricVideos="true"
filterCompilations="true"
maxSearchResults="40"
ytdlpRateLimit="2"

# Download settings
downloadDelay="2"
maxRetries="3"

# Metadata
createNfoFiles="true"
createJpgThumbnails="true"

# Advanced yt-dlp options - DISABLES JSON FILES
ytdlpCacheDir="/config/extended/cache/ytdlp"

##### RESCAN BEHAVIOR
alwaysRescanArtists="true"
ignoreCompletionLogs="true"
