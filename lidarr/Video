    local isrc=""
    local recording_mbid=""
    local work_mbid=""
    local release_group_mbid=""
    local release_mbid=""
    local album_name=""
    local track_number=""
    local disc_number=""
    local recording_rating=""
    local recording_votes=""
    local bpm=""
    local musical_key=""
    local moods=""
    local styles=""
    local genres=""
    local composer=""
    local lyricist=""
    local producer=""
    local engineer=""
    
