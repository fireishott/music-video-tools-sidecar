            isrc=$(echo "$recording_json" | jq -r '.isrcs[0] // empty')
            work_mbid=$(echo "$recording_json" | jq -r '.["work-rels"][0].work.id // empty')
            
            # Get first release info
            local first_release=$(echo "$recording_json" | jq -r '.releases[0] // empty')
            if [ ! -z "$first_release" ]; then
                release_mbid=$(echo "$first_release" | jq -r '.id // empty')
                album_name=$(echo "$first_release" | jq -r '.title // empty')
                release_group_mbid=$(echo "$first_release" | jq -r '.["release-group"].id // empty')
                
                # Try to get track number
                local media=$(echo "$first_release" | jq -r '.media[0] // empty')
                if [ ! -z "$media" ]; then
                    disc_number=$(echo "$media" | jq -r '.position // empty')
                    local tracks=$(echo "$media" | jq -r '.tracks // empty')
                    if [ ! -z "$tracks" ] && [ "$tracks" != "null" ]; then
                        track_number=$(echo "$tracks" | jq -r '.[0].number // empty')
                    fi
                fi
            fi
            
            # Get rating
            recording_rating=$(echo "$recording_json" | jq -r '.rating.value // empty')
            recording_votes=$(echo "$recording_json" | jq -r '.rating.votes // empty')
            
            # Extract tags (if technical metadata enabled)
            if [ "$ENABLE_TECHNICAL_METADATA" = "true" ]; then
                local tags_list=$(echo "$recording_json" | jq -r '.tags[]? | .name')
                while IFS= read -r tag; do
                    [ -z "$tag" ] && continue
                    if [[ "$tag" == bpm:* ]]; then
                        bpm=$(echo "$tag" | sed 's/bpm://')
                    elif [[ "$tag" == key:* ]]; then
                        musical_key=$(echo "$tag" | sed 's/key://')
                    elif [[ "$tag" == mood:* ]]; then
                        moods="$moods"$'\n'"$(echo "$tag" | sed 's/mood://')"
                    elif [[ "$tag" == style:* ]]; then
                        styles="$styles"$'\n'"$(echo "$tag" | sed 's/style://')"
                    fi
                done <<< "$tags_list"
            fi
            
            # Get genres
            genres=$(echo "$recording_json" | jq -r '.genres[]?.name')
            
            # Get work info if available
            if [ ! -z "$work_mbid" ] && [ "$ENABLE_TECHNICAL_METADATA" = "true" ]; then
                local work_json=$(GetWorkInfo "$work_mbid")
                if [ ! -z "$work_json" ]; then
                    composer=$(echo "$work_json" | jq -r '.["artist-rels"][]? | select(.type == "composer") | .artist.name' | head -1)
                    lyricist=$(echo "$work_json" | jq -r '.["artist-rels"][]? | select(.type == "lyricist") | .artist.name' | head -1)
                fi
            fi
            
            # Get producer and engineer from artist-rels
            if [ "$ENABLE_TECHNICAL_METADATA" = "true" ]; then
                producer=$(echo "$recording_json" | jq -r '.["artist-rels"][]? | select(.type == "producer") | .artist.name' | head -1)
                engineer=$(echo "$recording_json" | jq -r '.["artist-rels"][]? | select(.type == "engineer") | .artist.name' | head -1)
            fi
            
            log "$artist :: Found MusicBrainz recording: $recording_mbid"
            [ ! -z "$album_name" ] && log "$artist :: Album: $album_name"
            [ ! -z "$isrc" ] && log "$artist :: ISRC: $isrc"
            [ ! -z "$bpm" ] && log "$artist :: BPM: $bpm"
            [ ! -z "$musical_key" ] && log "$artist :: Key: $musical_key"
        else
            log "$artist :: No MusicBrainz match found for: $base_song_title"
        fi
    fi
    
    # Get Lidarr artist genres
    local artistGenres=""
    local OLDIFS="$IFS"
    IFS=$'\n'
    artistGenres=($(echo "$artist_data" | jq -r ".genres[]" 2>/dev/null))
    IFS="$OLDIFS"
    
    # Start building NFO
    {
        echo "<musicvideo>"
        
        # Core metadata
        echo "  <title>$title</title>"
        echo "  <artist>$artist</artist>"
        echo "  <year>$year</year>"
        [ ! -z "$formatted_date" ] && echo "  <premiered>$formatted_date</premiered>"
        [ ! -z "$formatted_date" ] && echo "  <releasedate>$formatted_date</releasedate>"
        
        # MusicBrainz IDs
        echo "  <musicbrainzartistid>$artist_mbid</musicbrainzartistid>"
        [ ! -z "$recording_mbid" ] && echo "  <musicbrainzrecordingid>$recording_mbid</musicbrainzrecordingid>"
        [ ! -z "$work_mbid" ] && echo "  <musicbrainzworkid>$work_mbid</musicbrainzworkid>"
        [ ! -z "$release_group_mbid" ] && echo "  <musicbrainzreleasegroupid>$release_group_mbid</musicbrainzreleasegroupid>"
        [ ! -z "$release_mbid" ] && echo "  <musicbrainzalbumid>$release_mbid</musicbrainzalbumid>"
        
        # Album info
        [ ! -z "$album_name" ] && echo "  <album>$album_name</album>"
        echo "  <albumartist>$artist</albumartist>"
        [ ! -z "$track_number" ] && echo "  <track>$track_number</track>"
        [ ! -z "$disc_number" ] && echo "  <disc>$disc_number</disc>"
        
        # ISRC
        [ ! -z "$isrc" ] && echo "  <isrc>$isrc</isrc>"
        
        # Composers, lyricists, producers (if enabled)
        if [ "$ENABLE_TECHNICAL_METADATA" = "true" ]; then
            [ ! -z "$composer" ] && echo "  <composer>$composer</composer>"
            [ ! -z "$lyricist" ] && echo "  <lyricist>$lyricist</lyricist>"
            [ ! -z "$producer" ] && echo "  <producer>$producer</producer>"
            [ ! -z "$engineer" ] && echo "  <engineer>$engineer</engineer>"
        fi
        
        # Genres (from Lidarr and MusicBrainz)
        if [ ! -z "$artistGenres" ]; then
            for genre_item in "${artistGenres[@]}"; do
                [ ! -z "$genre_item" ] && echo "  <genre>$genre_item</genre>"
            done
        fi
        
        if [ ! -z "$genres" ]; then
            while IFS= read -r genre_item; do
                [ ! -z "$genre_item" ] && echo "  <genre>$genre_item</genre>"
            done <<< "$genres"
        fi
        
        # Styles and moods (if enabled)
        if [ "$ENABLE_TECHNICAL_METADATA" = "true" ]; then
            if [ ! -z "$styles" ]; then
                while IFS= read -r style_item; do
                    [ ! -z "$style_item" ] && echo "  <style>$style_item</style>"
                done <<< "$styles"
            fi
            
            if [ ! -z "$moods" ]; then
                while IFS= read -r mood_item; do
                    [ ! -z "$mood_item" ] && echo "  <mood>$mood_item</mood>"
                done <<< "$moods"
            fi
        fi
        
        # YouTube tags as additional metadata
        if [ ! -z "$tags" ]; then
            while IFS= read -r tag_item; do
                [ ! -z "$tag_item" ] && echo "  <tag>$tag_item</tag>"
            done <<< "$tags"
        fi
        
        # Technical metadata (if enabled)
        if [ "$ENABLE_TECHNICAL_METADATA" = "true" ]; then
            [ ! -z "$bpm" ] && echo "  <bpm>$bpm</bpm>"
            [ ! -z "$musical_key" ] && echo "  <key>$musical_key</key>"
        fi
        [ ! -z "$duration" ] && echo "  <duration>$duration</duration>"
        
        # MusicBrainz ratings
        [ ! -z "$recording_rating" ] && echo "  <rating>$recording_rating</rating>"
        [ ! -z "$recording_votes" ] && echo "  <votes>$recording_votes</votes>"
        
        # Video statistics with timestamp
        if [ "$ENABLE_YOUTUBE_STATS" = "true" ]; then
            [ ! -z "$views" ] && echo "  <views>$views</views>"
            [ ! -z "$likes" ] && echo "  <likes>$likes</likes>"
        fi
        echo "  <lastupdated>$current_time</lastupdated>"
        
        # Channel info
        [ ! -z "$channel" ] && echo "  <channel>$channel</channel>"
        [ ! -z "$channel_id" ] && echo "  <channel_id>$channel_id</channel_id>"
        
        # Featured artists as actors (if enabled)
        if [ "$ENABLE_FEATURED_ARTISTS" = "true" ] && [ ! -z "$featured_artists" ]; then
            local order=1
            # Split by commas, &, and, etc.
            echo "$featured_artists" | sed 's/[,&]/\n/g' | sed 's/ and /\n/g' | while IFS= read -r feat_artist; do
                feat_artist=$(echo "$feat_artist" | sed 's/^[[:space:]]*//' | sed 's/[[:space:]]*$//')
                [ ! -z "$feat_artist" ] && [ "$feat_artist" != "$artist" ] && echo "  <actor>"
                [ ! -z "$feat_artist" ] && [ "$feat_artist" != "$artist" ] && echo "    <name>$feat_artist</name>"
                [ ! -z "$feat_artist" ] && [ "$feat_artist" != "$artist" ] && echo "    <role>Featured Artist</role>"
                [ ! -z "$feat_artist" ] && [ "$feat_artist" != "$artist" ] && echo "    <order>$order</order>"
                [ ! -z "$feat_artist" ] && [ "$feat_artist" != "$artist" ] && echo "  </actor>"
                order=$((order + 1))
            done
        fi
        
        # Source info
        echo "  <source>$source</source>"
        echo "  <source_url>https://www.youtube.com/watch?v=$video_id</source_url>"
        echo "  <uniqueid type=\"YouTube\">$video_id</uniqueid>"
        [ ! -z "$recording_mbid" ] && echo "  <uniqueid type=\"MusicBrainz\">$recording_mbid</uniqueid>"
        
        # Description
        local description="$title by $artist"
        [ ! -z "$album_name" ] && description="$description from the album $album_name"
        [ ! -z "$year" ] && description="$description released in $year"
        [ ! -z "$featured_artists" ] && description="$description featuring $featured_artists"
        echo "  <plot>$description</plot>"
        echo "  <outline>Music video</outline>"
        [ ! -z "$album_name" ] && echo "  <tagline>From the album $album_name</tagline>"
        
        # Thumbnail
        echo "  <thumb>${plex_filename}.jpg</thumb>"
        
        echo "</musicvideo>"
    } > "$nfo"
    
    # Format XML
    if command -v tidy &>/dev/null; then
        tidy -w 2000 -i -m -xml "$nfo" &>/dev/null
    fi
    chmod 666 "$nfo"
    
    # Count actual fields
    local field_count=$(grep -c "<[a-z]" "$nfo" 2>/dev/null || echo "0")
    if [ "$is_update" = "true" ]; then
        log "$artist :: ✅ NFO upgraded with $field_count metadata fields"
    else
        log "$artist :: NFO created with $field_count metadata fields"
    fi
}

# Download thumbnail
DownloadThumb() {
    local artist_folder="$1"
    local plex_filename="$2"
    local video_id="$3"
    
    local thumb_file="$videoPath/$artist_folder/${plex_filename}.jpg"
    
    if [ -f "$thumb_file" ]; then
        return
    fi
    
    curl -s "https://img.youtube.com/vi/$video_id/maxresdefault.jpg" -o "$thumb_file" 2>/dev/null
    
    if [ ! -f "$thumb_file" ] || [ ! -s "$thumb_file" ]; then
        curl -s "https://img.youtube.com/vi/$video_id/hqdefault.jpg" -o "$thumb_file" 2>/dev/null
    fi
    
    if [ -f "$thumb_file" ] && [ -s "$thumb_file" ]; then
        chmod 666 "$thumb_file"
    else
        rm -f "$thumb_file" 2>/dev/null
    fi
}

# Force MKV format in download - NO JSON FILES
DownloadVideo() {
    local url="$1"
    local filename="$2"
    
    if [ -d "$videoDownloadPath/incomplete" ]; then
        rm -rf "$videoDownloadPath/incomplete"
    fi

    if [ ! -d "$videoDownloadPath/incomplete" ]; then
        mkdir -p "$videoDownloadPath/incomplete"
        chmod 777 "$videoDownloadPath/incomplete"
    fi

    # Force MKV format with best quality - NO JSON FILES
    yt-dlp -f "bestvideo[height<=1080]+bestaudio/best[height<=1080]" \
        --merge-output-format mkv \
        --remux-video mkv \
        --no-write-info-json \
        --no-write-description \
        --no-write-thumbnail \
        --no-write-subs \
        -o "$videoDownloadPath/incomplete/${filename}.%(ext)s" \
        --no-mtime \
        --geo-bypass "$url"
    
    if [ -f "$videoDownloadPath/incomplete/${filename}.mkv" ]; then
        chmod 666 "$videoDownloadPath/incomplete/${filename}.mkv"
        downloadFailed=false
    else
        downloadFailed=true
    fi
}

# Scan and upgrade existing NFO files for an artist
UpgradeExistingNFOs() {
    local artist="$1"
    local artist_folder="$2"
    local artist_mbid="$3"
    local artist_data="$4"
    
    if [ ! -d "$videoPath/$artist_folder" ]; then
        return
    fi
    
    log "$artist :: Scanning for NFO files that need attention..."
    
    local upgraded=0
    local stats_updated=0
    local id_recovered=0
    local skipped=0
    
    # Find all NFO files in artist folder
    find "$videoPath/$artist_folder" -maxdepth 1 -name "*.nfo" -type f | while read nfo_file; do
        # First, check if NFO has YouTube ID
        local existing_id=$(grep -o '<uniqueid.*YouTube.*>.*</uniqueid>' "$nfo_file" | head -1 | sed 's/.*>\(.*\)<\/uniqueid>/\1/')
        
        # If no ID and recovery is enabled, try to recover it
        if [ -z "$existing_id" ] && [ "$ENABLE_ID_RECOVERY" = "true" ]; then
            log "$artist :: NFO missing YouTube ID, attempting recovery..."
            if RecoverYouTubeID "$nfo_file"; then
                id_recovered=$((id_recovered + 1))
                # Re-extract ID after recovery
                existing_id=$(grep -o '<uniqueid.*YouTube.*>.*</uniqueid>' "$nfo_file" | head -1 | sed 's/.*>\(.*\)<\/uniqueid>/\1/')
            fi
        fi
        
        # Check if NFO needs stats update (only if we have an ID)
        if [ ! -z "$existing_id" ] && [ "$UPDATE_STATS_ON_EXISTING" = "true" ] && NeedsStatsUpdate "$nfo_file"; then
            # Parse existing NFO to get metadata
            local nfo_data=$(ParseExistingNFO "$nfo_file")
            local existing_title=$(echo "$nfo_data" | cut -d'|' -f1)
            local existing_artist=$(echo "$nfo_data" | cut -d'|' -f2)
            local existing_year=$(echo "$nfo_data" | cut -d'|' -f3)
            
            # Get base filename without extension
            local base_filename=$(basename "$nfo_file" .nfo)
            
            log "$artist :: Stats outdated for: $existing_title - updating..."
            UpdateYouTubeStats "$artist_folder" "$base_filename" "$existing_id" "$nfo_file"
            stats_updated=$((stats_updated + 1))
        fi
        
        # Check if NFO is already rich
        if IsRichNFO "$nfo_file"; then
            skipped=$((skipped + 1))
            continue
        fi
        
        # Skip if we still don't have an ID
        if [ -z "$existing_id" ]; then
            log "$artist :: Cannot upgrade $(basename "$nfo_file") - missing YouTube ID"
            continue
        fi
        
        # Parse existing NFO to get metadata
        local nfo_data=$(ParseExistingNFO "$nfo_file")
        local existing_title=$(echo "$nfo_data" | cut -d'|' -f1)
        local existing_artist=$(echo "$nfo_data" | cut -d'|' -f2)
        local existing_year=$(echo "$nfo_data" | cut -d'|' -f3)
        
        # Get base filename without extension
        local base_filename=$(basename "$nfo_file" .nfo)
        local video_file=""
        
        # Find corresponding video file
        if [ -f "$videoPath/$artist_folder/$base_filename.mkv" ]; then
            video_file="$base_filename.mkv"
        elif [ -f "$videoPath/$artist_folder/$base_filename.mp4" ]; then
            video_file="$base_filename.mp4"
        else
            log "$artist :: Cannot upgrade $(basename "$nfo_file") - missing video file"
            continue
        fi
        
        log "$artist :: Upgrading NFO for: $existing_title"
        
        # Clean titles for better matching
        local song_title=$(CleanTitle "$existing_title" "$artist")
        local base_song_title=$(ExtractBaseSongTitle "$song_title")
        
        # Recreate rich NFO
        CreateRichNFO "$artist_folder" "$base_filename" "$existing_title" "$artist" "$artist_mbid" "$existing_year" "$artist_data" "youtube" "$existing_id" "$song_title" "$base_song_title" "true"
        
        upgraded=$((upgraded + 1))
    done
    
    if [ $upgraded -gt 0 ] || [ $stats_updated -gt 0 ] || [ $id_recovered -gt 0 ]; then
        log "$artist :: ✅ Upgraded $upgraded NFO files, updated stats for $stats_updated videos, recovered $id_recovered IDs"
    fi
}

# YouTube Direct Search with strict artist filtering
SearchYouTubeDirect() {
    local artist="$1"
    local artist_folder="$2"
    local artist_mbid="$3"
    local artist_data="$4"
    
    log "$artist :: Searching YouTube..."
    
    # First, upgrade any existing NFO files
    UpgradeExistingNFOs "$artist" "$artist_folder" "$artist_mbid" "$artist_data"
    
    local temp_processed="/tmp/processed_${artist_mbid}.txt"
    > "$temp_processed"
    
    # More specific search - include channel info for verification
    local yt_search_results=$(yt-dlp "ytsearch40:${artist} official music video OR ${artist} - Topic" \
        --print "%(title)s|%(id)s|%(upload_date)s|%(view_count)s|%(channel)s" \
        --no-warnings 2>/dev/null | head -40)
    
    if [ -n "$yt_search_results" ]; then
        # Sort by view count (highest first)
        local total_found=$(echo "$yt_search_results" | wc -l)
        local filtered=0
        local existing=0
        local downloaded=0
        
        # Process results line by line
        while IFS='|' read title id date views channel; do
            # Skip empty lines
            [ -z "$title" ] && continue
            
            local year="${date:0:4}"
            
            # Skip if already processed
            if grep -q "^$id$" "$temp_processed"; then
                continue
            fi
            
            # STRICT artist verification
            local title_lower=$(echo "$title" | tr '[:upper:]' '[:lower:]')
            local artist_lower=$(echo "$artist" | tr '[:upper:]' '[:lower:]')
            local channel_lower=$(echo "$channel" | tr '[:upper:]' '[:lower:]')
            
            # Skip if artist name NOT in title AND NOT in channel
            if [[ "$title_lower" != *"$artist_lower"* ]] && [[ "$channel_lower" != *"$artist_lower"* ]] && [[ "$channel_lower" != *"${artist_lower}vevo"* ]]; then
                filtered=$((filtered + 1))
                continue
            fi
            
            # Skip lyric/audio videos
            if echo "$title" | grep -i -E "(lyric|lyrics|audio|interview|trailer|teaser|behind the scenes|making of|official audio|visualizer)" >/dev/null; then
                filtered=$((filtered + 1))
                continue
            fi
            
            # Skip if title is too short or looks like a compilation
            if [ ${#title} -lt 5 ] || echo "$title" | grep -i -E "(full album|playlist|mix|megamix|compilation)" >/dev/null; then
                filtered=$((filtered + 1))
                continue
            fi
            
            local video_type=$(GetVideoType "$title")
            local song_title=$(CleanTitle "$title" "$artist")
            local base_song_title=$(ExtractBaseSongTitle "$song_title")
            local plex_filename="${song_title}${video_type}"
            local videoDownloadUrl="https://www.youtube.com/watch?v=$id"
            
            if [[ ! "$videoDownloadUrl" =~ watch\?v=[a-zA-Z0-9_-]{11}$ ]]; then
                continue
            fi
            
            echo "$id" >> "$temp_processed"
            
            # Check by video ID in NFO files
            local id_found=false
            if [ -d "$videoPath/$artist_folder" ]; then
                if grep -q "$id" "$videoPath/$artist_folder"/*.nfo 2>/dev/null; then
                    log "$artist :: Already have video with ID: $id"
                    id_found=true
                    existing=$((existing + 1))
                    
                    # Check if stats need update
                    if [ "$UPDATE_STATS_ON_EXISTING" = "true" ]; then
                        local nfo_file=$(grep -l "$id" "$videoPath/$artist_folder"/*.nfo | head -1)
                        if [ ! -z "$nfo_file" ] && NeedsStatsUpdate "$nfo_file"; then
                            log "$artist :: Stats outdated for existing video, updating..."
                            local base_filename=$(basename "$nfo_file" .nfo)
                            UpdateYouTubeStats "$artist_folder" "$base_filename" "$id" "$nfo_file"
                        fi
                    fi
                fi
            fi
            
            if [ "$id_found" = true ]; then
                continue
            fi
            
            # Check for existing video files with exact name
            if [ -f "$videoPath/$artist_folder/${plex_filename}.mkv" ]; then
                log "$artist :: Already have: ${plex_filename}.mkv"
                
                if [ ! -f "$videoPath/$artist_folder/${plex_filename}.nfo" ]; then
                    log "$artist :: Creating missing NFO"
                    CreateRichNFO "$artist_folder" "$plex_filename" "$title" "$artist" "$artist_mbid" "$year" "$artist_data" "youtube" "$id" "$song_title" "$base_song_title"
                elif ! IsRichNFO "$videoPath/$artist_folder/${plex_filename}.nfo"; then
                    log "$artist :: Upgrading poor NFO"
                    CreateRichNFO "$artist_folder" "$plex_filename" "$title" "$artist" "$artist_mbid" "$year" "$artist_data" "youtube" "$id" "$song_title" "$base_song_title" "true"
                elif [ "$UPDATE_STATS_ON_EXISTING" = "true" ] && NeedsStatsUpdate "$videoPath/$artist_folder/${plex_filename}.nfo"; then
                    log "$artist :: Stats outdated, updating..."
                    UpdateYouTubeStats "$artist_folder" "$plex_filename" "$id" "$videoPath/$artist_folder/${plex_filename}.nfo"
                fi
                
                if [ ! -f "$videoPath/$artist_folder/${plex_filename}.jpg" ]; then
                    DownloadThumb "$artist_folder" "$plex_filename" "$id"
                fi
                
                existing=$((existing + 1))
                continue
            fi
            
            log "$artist :: Downloading: $title -> ${plex_filename}.mkv"
            downloaded=$((downloaded + 1))
            
            DownloadVideo "$videoDownloadUrl" "$plex_filename"
            
            if [ "$downloadFailed" = "true" ]; then
                log "$artist :: Download failed"
                rm -rf "$videoDownloadPath/incomplete"/*
                downloaded=$((downloaded - 1))
                continue
            fi
            
            if [ ! -d "$videoPath/$artist_folder" ]; then
                mkdir -p "$videoPath/$artist_folder"
                chmod 777 "$videoPath/$artist_folder"
            fi
            
            mv $videoDownloadPath/incomplete/* "$videoPath/$artist_folder"/ 2>/dev/null
            
            local final_file=$(find "$videoPath/$artist_folder" -maxdepth 1 -name "${plex_filename}.mkv" -type f | head -1)
            
            if [ -n "$final_file" ]; then
                log "$artist :: ✅ Downloaded: $(basename "$final_file")"
            fi
            
            CreateRichNFO "$artist_folder" "$plex_filename" "$title" "$artist" "$artist_mbid" "$year" "$artist_data" "youtube" "$id" "$song_title" "$base_song_title"
            DownloadThumb "$artist_folder" "$plex_filename" "$id"
            
            rm -rf "$videoDownloadPath/incomplete" 2>/dev/null
            sleep 2
        done <<< "$(echo "$yt_search_results" | sort -t'|' -k4 -rn)"
        
        log "$artist :: Found $total_found videos, filtered $filtered (wrong artist/type), $existing existing, $downloaded downloaded"
    else
        log "$artist :: No videos found"
    fi
    
    rm -f "$temp_processed"
}

# Main processing loop
VideoProcess() {
    log "Starting video download process"
    
    # Use API key from extended.conf
    LIDARR_API_KEY="$LidarrApiKey"
    
    if [ -z "$videoDownloadTag" ]; then
        lidarrArtists=$(curl -s "http://localhost:8686/api/v1/artist?apikey=$LIDARR_API_KEY" | jq -r .[])
        lidarrArtistIds=$(echo "$lidarrArtists" | jq -r .id)
    else
        lidarrArtists=$(curl -s "http://localhost:8686/api/v1/tag/detail?apikey=$LIDARR_API_KEY" | jq -r -M ".[] | select(.label == \"$videoDownloadTag\") | .artistIds")
        lidarrArtistIds=$(echo "$lidarrArtists" | jq -r .[])
    fi
    
    lidarrArtistIdsCount=$(echo "$lidarrArtistIds" | wc -l)
    processCount=0
    
    for lidarrArtistId in $(echo $lidarrArtistIds); do
        processCount=$((processCount + 1))
        lidarrArtistData=$(curl -s "http://localhost:8686/api/v1/artist/$lidarrArtistId?apikey=$LIDARR_API_KEY")
        lidarrArtistName=$(echo "$lidarrArtistData" | jq -r .artistName)
        lidarrArtistMusicbrainzId=$(echo "$lidarrArtistData" | jq -r .foreignArtistId)
        
        if [ "$lidarrArtistName" == "Various Artists" ]; then
            log "[$processCount/$lidarrArtistIdsCount] $lidarrArtistName :: Skipping"
            continue
        fi
        
        lidarrArtistPath="$(echo "$lidarrArtistData" | jq -r ".path")"
        lidarrArtistFolder="$(basename "$lidarrArtistPath")"
        lidarrArtistFolderNoDisambig="$(echo "$lidarrArtistFolder" | sed "s/ (.*)$//g" | sed "s/\.$//g")"
        
        log "[$processCount/$lidarrArtistIdsCount] Processing: $lidarrArtistName"
        
        SearchYouTubeDirect "$lidarrArtistName" "$lidarrArtistFolderNoDisambig" "$lidarrArtistMusicbrainzId" "$lidarrArtistData"
    done
    
    log "Video download process complete"
}

# Configuration
if [ -z "$videoContainer" ]; then
    videoContainer="mkv"
fi

