log "Rich NFO threshold: $RICH_NFO_THRESHOLD fields"
log "YouTube ID recovery: $ENABLE_ID_RECOVERY"
log "MusicBrainz enabled: $ENABLE_MUSICBRAINZ"
log "YouTube Stats enabled: $ENABLE_YOUTUBE_STATS"
log "Featured Artists enabled: $ENABLE_FEATURED_ARTISTS"
