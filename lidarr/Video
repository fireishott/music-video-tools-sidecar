#!/usr/bin/with-contenv bash
# ==============================================================================
# Video Download Script for Lidarr
# ==============================================================================
# Author: Curtis Freeman
# GitHub: https://github.com/fireishott/arr-scripts_Video
# Version: 6.4
#
# This script downloads official music videos from YouTube and creates/updates
# richly detailed NFO metadata for Plex/Jellyfin/Emby with MusicBrainz data.
# Includes weekly YouTube stats updates and timestamp tracking.
# ==============================================================================

scriptVersion="6.4"
scriptName="Video"

# Setup logging - ensure directory exists
LOG_PATH="/config/extended/logs"
mkdir -p "$LOG_PATH"
LOG_FILE="$LOG_PATH/Video-$scriptVersion.log"

# Stats update interval in seconds (7 days = 604800 seconds)
STATS_UPDATE_INTERVAL=604800

# Logging function with consistent format
log() {
    local message="$(date '+%Y-%m-%d %H:%M:%S') :: $scriptName :: $scriptVersion :: $1"
    echo "$message"
    echo "$message" >> "$LOG_FILE"
}

### Import Settings
source /config/extended.conf 2>/dev/null || {
    log "ERROR: No configuration file found"
    log "Please create /config/extended.conf"
    exit 1
}

#### Import Functions (if available)
if [ -f "/config/extended/functions" ]; then
    source /config/extended/functions
fi

# Manual API verification - use API key from extended.conf
if [ -z "$LidarrApiKey" ]; then
    log "ERROR: LidarrApiKey not set in extended.conf"
    exit 1
fi

LIDARR_API_KEY="$LidarrApiKey"

if ! curl -s "http://localhost:8686/api/v1/system/status?apikey=$LIDARR_API_KEY" | jq -e . >/dev/null 2>&1; then
    log "ERROR: Cannot connect to Lidarr API"
    exit 1
fi

# Rate limiting for MusicBrainz (respect their servers)
MUSICBRAINZ_RATE_LIMIT=1  # seconds between requests

# Define rich NFO required fields
RICH_NFO_REQUIRED_FIELDS=(
    "musicbrainzrecordingid"
    "album"
    "isrc"
    "bpm"
    "key"
    "mood"
    "style"
    "views"
    "likes"
    "lastupdated"
)

# Determine video type based on title content
GetVideoType() {
    local title="$1"
    local lower_title=$(echo "$title" | tr '[:upper:]' '[:lower:]')
    
    if echo "$lower_title" | grep -q -E "(behind.?the.?scenes|making of|on the set)"; then
        echo "-behindthescenes"
    elif echo "$lower_title" | grep -q -E "(concert|live performance|live at|tour)"; then
        echo "-concert"
    elif echo "$lower_title" | grep -q -E "(interview|q&a|qa)"; then
        echo "-interview"
    elif echo "$lower_title" | grep -q -E "(live|live video|live version)"; then
        if ! echo "$lower_title" | grep -q -E "(concert|tour)"; then
            echo "-live"
        else
            echo "-concert"
        fi
    elif echo "$lower_title" | grep -q -E "(lyric|lyrics|lyric video)"; then
        echo "-lyrics"
    else
        echo "-video"
    fi
}

# Check if NFO needs stats update based on lastupdated timestamp
NeedsStatsUpdate() {
    local nfo_file="$1"
    
    if [ ! -f "$nfo_file" ]; then
        return 0  # Doesn't exist, needs update
    fi
    
    # Check if lastupdated tag exists
    if ! grep -q "<lastupdated>" "$nfo_file"; then
        return 0  # No timestamp, needs update
    fi
    
    # Extract lastupdated timestamp
    local last_updated=$(grep -o '<lastupdated>[0-9]*</lastupdated>' "$nfo_file" | sed 's/<lastupdated>\([0-9]*\)<\/lastupdated>/\1/')
    
    if [ -z "$last_updated" ]; then
        return 0  # Invalid timestamp, needs update
    fi
    
    local current_time=$(date +%s)
    local time_diff=$((current_time - last_updated))
    
    if [ $time_diff -ge $STATS_UPDATE_INTERVAL ]; then
        return 0  # Needs update
    else
        return 1  # Doesn't need update
    fi
}

# Check if NFO is rich (has all required fields)
IsRichNFO() {
    local nfo_file="$1"
    
    if [ ! -f "$nfo_file" ]; then
        return 1
    fi
    
    local missing_fields=0
    for field in "${RICH_NFO_REQUIRED_FIELDS[@]}"; do
        if ! grep -q "<$field>" "$nfo_file"; then
            missing_fields=$((missing_fields + 1))
        fi
    done
    
    # Consider rich if it has at least 7 of the required fields
    if [ $missing_fields -le 3 ]; then
        return 0  # Is rich
    else
        return 1  # Needs enrichment
    fi
}

# Clean title to return ONLY the song title (no artist)
CleanTitle() {
    local title="$1"
    local artist="$2"
    
    local cleaned="$title"
    local artist_escaped=$(printf '%s\n' "$artist" | sed 's/[[\.*^$()+?{|]/\\&/g')
    
    # Remove artist name from beginning if present
    if [[ "$cleaned" =~ ^[[:space:]]*${artist_escaped}[[:space:]]*[-:][[:space:]]*(.*)$ ]] || \
       [[ "$cleaned" =~ ^[[:space:]]*${artist_escaped}[[:space:]]*[-–—][[:space:]]*(.*)$ ]]; then
        cleaned="${BASH_REMATCH[1]}"
    elif [[ "$cleaned" =~ ^[[:space:]]*${artist_escaped}[[:space:]]+(.*)$ ]]; then
        cleaned="${BASH_REMATCH[1]}"
    fi
    
    # Remove common video descriptors
    cleaned=$(echo "$cleaned" | \
        sed -E 's/ [\[\(]?[Oo]fficial[\]\)]? [\[\(]?[Mm]usic[\]\)]? [\[\(]?[Vv]ideo[\]\)]?//g' | \
        sed -E 's/ [\[\(]?[Oo]fficial[\]\)]? [\[\(]?[Vv]ideo[\]\)]?//g' | \
        sed -E 's/ [\[\(]?[Mm]usic[\]\)]? [\[\(]?[Vv]ideo[\]\)]?//g' | \
        sed -E 's/ [\[\(]?[Oo]fficial[\]\)]?//g' | \
        sed -E 's/ [\[\(]?[Vv]ideo[\]\)]?//g' | \
        sed -E 's/ [\[\(]?[Hh][Dd][\]\)]?//g' | \
        sed -E 's/ [\[\(]?[Kk]?[4Kk][\]\)]?//g' | \
        sed -E 's/ [\[\(]?[Rr]emaster[\]\)]?//g' | \
        sed -E 's/ [\[\(]?[Uu]pscaled[\]\)]? [Tt]o [0-9]+[Kk]?//g' | \
        sed -E 's/ [\[\(]?[Ff]ull [Hh][Dd][\]\)]?//g' | \
        sed -E 's/ [\[\(]?[Hh][Qq][\]\)]?//g' | \
        sed -E 's/ feat\.? / ft /g' | \
        sed -E 's/ featuring / ft /g' | \
        sed 's/  */ /g' | \
        sed 's/^[[:space:]]*//' | \
        sed 's/[[:space:]]*$//')
    
    # Clean up any remaining special characters
    cleaned=$(echo "$cleaned" | sed 's%/% - %g' | sed 's/[\\/*?:"<>|]//g' | sed 's/  */ /g' | sed 's/^[[:space:]]*//' | sed 's/[[:space:]]*$//')
    
    # If still empty, use a fallback
    if [ -z "$cleaned" ]; then
        cleaned="Unknown Title"
    fi
    
    echo "$cleaned"
}

# Extract base song title (remove feat., ft., etc.) for better matching
ExtractBaseSongTitle() {
    local title="$1"
    
    # Remove common feature indicators and following text
    local base=$(echo "$title" | sed -E 's/ [(\[]?(feat\.|featuring|ft\.|ft|with).*$//i' | \
                         sed -E 's/ [(\[]?(official video|music video|official music video).*$//i' | \
                         sed -E 's/ [(\[]?[0-9]{4}.*$//i' | \
                         sed 's/[[:space:]]*$//')
    
    echo "$base"
}

# Extract featured artists from title
ExtractFeaturedArtists() {
    local title="$1"
    
    # Try to extract featured artists after feat./ft./with
    if echo "$title" | grep -q -i -E "(feat\.|featuring|ft\.|ft|with)"; then
        local featured=$(echo "$title" | sed -E 's/.* (feat\.|featuring|ft\.|ft|with) //i' | \
                                sed -E 's/ [(\[]?(official video|music video|official music video).*$//i' | \
                                sed 's/[[:space:]]*$//')
        echo "$featured"
    fi
}

# Get MusicBrainz recording ID by ISRC if available
GetRecordingByISRC() {
    local isrc="$1"
    
    if [ -z "$isrc" ]; then
        return 1
    fi
    
    sleep $MUSICBRAINZ_RATE_LIMIT
    local response=$(curl -s "https://musicbrainz.org/ws/2/recording/?query=isrc:$isrc&fmt=json&inc=artists+releases+isrcs+tags+genres+work-rels+artist-rels+url-rels+ratings" 2>/dev/null)
    
    if [ ! -z "$response" ] && [ "$(echo "$response" | jq -r '.count // 0')" -gt 0 ]; then
        echo "$response" | jq -r '.recordings[0]'
        return 0
    fi
    return 1
}

# Get MusicBrainz recording ID by artist and title
GetRecordingByArtistAndTitle() {
    local artist="$1"
    local title="$2"
    
    if [ -z "$artist" ] || [ -z "$title" ]; then
        return 1
    fi
    
    # URL encode for query
    local encoded_artist=$(echo "$artist" | sed 's/ /%20/g' | sed 's/&/%26/g')
    local encoded_title=$(echo "$title" | sed 's/ /%20/g' | sed 's/&/%26/g')
    
    sleep $MUSICBRAINZ_RATE_LIMIT
    local response=$(curl -s "https://musicbrainz.org/ws/2/recording/?query=artist:${encoded_artist}%20AND%20recording:${encoded_title}&fmt=json&inc=artists+releases+isrcs+tags+genres+work-rels+artist-rels+url-rels+ratings" 2>/dev/null)
    
    if [ ! -z "$response" ] && [ "$(echo "$response" | jq -r '.count // 0')" -gt 0 ]; then
        echo "$response" | jq -r '.recordings[0]'
        return 0
    fi
    return 1
}

# Get work information by MBID
GetWorkInfo() {
    local work_mbid="$1"
    
    if [ -z "$work_mbid" ]; then
        return 1
    fi
    
    sleep $MUSICBRAINZ_RATE_LIMIT
    local response=$(curl -s "https://musicbrainz.org/ws/2/work/$work_mbid?fmt=json&inc=artist-rels+tags+genres" 2>/dev/null)
    
    if [ ! -z "$response" ]; then
        echo "$response"
    fi
}

# Update YouTube stats for an existing video
UpdateYouTubeStats() {
    local artist_folder="$1"
    local plex_filename="$2"
    local video_id="$3"
    local nfo_file="$4"
    
    log "$(basename "$artist_folder") :: Updating YouTube stats for: $plex_filename"
    
    # Get fresh video info from YouTube
    local video_info=$(yt-dlp --dump-json "https://youtube.com/watch?v=$video_id" 2>/dev/null)
    local views=$(echo "$video_info" | jq -r '.view_count // empty')
    local likes=$(echo "$video_info" | jq -r '.like_count // empty')
    local current_time=$(date +%s)
    
    if [ -z "$views" ] && [ -z "$likes" ]; then
        log "$(basename "$artist_folder") :: No stats available for: $plex_filename"
        return 1
    fi
    
    # Update the NFO file with new stats
    local temp_nfo="${nfo_file}.tmp"
    
    # Read existing NFO and update views/likes/lastupdated
    awk -v views="$views" -v likes="$likes" -v timestamp="$current_time" '
        /<views>.*<\/views>/ {
            if (views != "") {
                print "  <views>" views "</views>"
            } else {
                print
            }
            next
        }
        /<likes>.*<\/likes>/ {
            if (likes != "") {
                print "  <likes>" likes "</likes>"
            } else {
                print
            }
            next
        }
        /<lastupdated>.*<\/lastupdated>/ {
            print "  <lastupdated>" timestamp "</lastupdated>"
            next
        }
        /<\/musicvideo>/ {
            # Add lastupdated if it doesnt exist
            if (!lastupdated_added) {
                print "  <lastupdated>" timestamp "</lastupdated>"
                lastupdated_added = 1
            }
            print
            next
        }
        { print }
    ' "$nfo_file" > "$temp_nfo"
    
    # Check if lastupdated was added (if it didn't exist)
    if ! grep -q "<lastupdated>" "$temp_nfo"; then
        # Insert before closing tag
        sed -i "/<\/musicvideo>/i \  <lastupdated>$current_time</lastupdated>" "$temp_nfo"
    fi
    
    mv "$temp_nfo" "$nfo_file"
    
    # Format XML
    if command -v tidy &>/dev/null; then
        tidy -w 2000 -i -m -xml "$nfo_file" &>/dev/null
    fi
    
    log "$(basename "$artist_folder") :: ✅ Stats updated - Views: $views, Likes: $likes"
    return 0
}

# Parse existing NFO to extract metadata
ParseExistingNFO() {
    local nfo_file="$1"
    
    # Extract title and artist from existing NFO
    local existing_title=$(grep -o '<title>.*</title>' "$nfo_file" | head -1 | sed 's/<title>\(.*\)<\/title>/\1/')
    local existing_artist=$(grep -o '<artist>.*</artist>' "$nfo_file" | head -1 | sed 's/<artist>\(.*\)<\/artist>/\1/')
    local existing_year=$(grep -o '<year>.*</year>' "$nfo_file" | head -1 | sed 's/<year>\(.*\)<\/year>/\1/')
    local existing_id=$(grep -o '<uniqueid.*YouTube.*>.*</uniqueid>' "$nfo_file" | head -1 | sed 's/.*>\(.*\)<\/uniqueid>/\1/')
    
    echo "$existing_title|$existing_artist|$existing_year|$existing_id"
}

# Create rich NFO file for video with all available metadata
CreateRichNFO() {
    local artist_folder="$1"
    local plex_filename="$2"
    local title="$3"
    local artist="$4"
    local artist_mbid="$5"
    local year="$6"
    local artist_data="$7"
    local source="$8"
    local video_id="$9"
    local song_title="${10}"
    local base_song_title="${11}"
    local is_update="${12:-false}"
    
    local nfo="$videoPath/$artist_folder/${plex_filename}.nfo"
    local is_rich=false
    local current_time=$(date +%s)
    
    # Check if this is just a stats update
    if [ "$is_update" = "stats" ]; then
        if [ -f "$nfo" ]; then
            UpdateYouTubeStats "$artist_folder" "$plex_filename" "$video_id" "$nfo"
        fi
        return
    fi
    
    # Check if existing NFO is already rich
    if [ -f "$nfo" ] && [ "$is_update" = "false" ]; then
        if IsRichNFO "$nfo"; then
            log "$artist :: NFO already rich, checking if stats need update"
            if NeedsStatsUpdate "$nfo"; then
                log "$artist :: Stats outdated (>=7 days), updating..."
                UpdateYouTubeStats "$artist_folder" "$plex_filename" "$video_id" "$nfo"
            fi
            return
        else
            log "$artist :: Existing NFO needs enrichment, upgrading..."
        fi
    fi
    
    # Get video info from YouTube
    local video_info=$(yt-dlp --dump-json "https://youtube.com/watch?v=$video_id" 2>/dev/null)
    local views=$(echo "$video_info" | jq -r '.view_count // empty')
    local likes=$(echo "$video_info" | jq -r '.like_count // empty')
    local duration=$(echo "$video_info" | jq -r '.duration // empty')
    local upload_date=$(echo "$video_info" | jq -r '.upload_date // empty')
    local channel=$(echo "$video_info" | jq -r '.channel // empty')
    local channel_id=$(echo "$video_info" | jq -r '.channel_id // empty')
    local categories=$(echo "$video_info" | jq -r '.categories[]? // empty')
    local tags=$(echo "$video_info" | jq -r '.tags[]? // empty' | head -5)
    
    local formatted_date=""
    if [ ! -z "$upload_date" ]; then
        formatted_date="${upload_date:0:4}-${upload_date:4:2}-${upload_date:6:2}"
    fi
    
    # Extract featured artists from title
    local featured_artists=$(ExtractFeaturedArtists "$title")
    
    # Try to find recording in MusicBrainz
    local recording_json=""
    local isrc=""
    local recording_mbid=""
    local work_mbid=""
    local release_group_mbid=""
    local release_mbid=""
    local album_name=""
    local track_number=""
    local disc_number=""
    local recording_rating=""
    local recording_votes=""
    local bpm=""
    local musical_key=""
    local moods=""
    local styles=""
    local genres=""
    local composer=""
    local lyricist=""
    local producer=""
    local engineer=""
    
    # Try multiple search strategies
    search_strategies=(
        "artist: $artist, base title: $base_song_title"
        "artist: $artist, original title: $song_title"
        "artist: $artist, clean title"
    )
    
    # First try by artist and base title
    log "$artist :: Searching MusicBrainz for: $artist - $base_song_title"
    recording_json=$(GetRecordingByArtistAndTitle "$artist" "$base_song_title")
    
    # Try with original title if base didn't work
    if [ -z "$recording_json" ] && [ "$base_song_title" != "$song_title" ]; then
        log "$artist :: Trying original title: $song_title"
        recording_json=$(GetRecordingByArtistAndTitle "$artist" "$song_title")
    fi
    
    # Try without the artist name in title (for remixes etc)
    if [ -z "$recording_json" ]; then
        local clean_for_search=$(echo "$base_song_title" | sed -E 's/ [(\[]?(remix|edit|version|mix).*$//i')
        if [ "$clean_for_search" != "$base_song_title" ]; then
            log "$artist :: Trying clean title: $clean_for_search"
            recording_json=$(GetRecordingByArtistAndTitle "$artist" "$clean_for_search")
        fi
    fi
    
    # Parse recording data if found
    if [ ! -z "$recording_json" ]; then
        recording_mbid=$(echo "$recording_json" | jq -r '.id // empty')
        isrc=$(echo "$recording_json" | jq -r '.isrcs[0] // empty')
        work_mbid=$(echo "$recording_json" | jq -r '.["work-rels"][0].work.id // empty')
        
        # Get first release info
        local first_release=$(echo "$recording_json" | jq -r '.releases[0] // empty')
        if [ ! -z "$first_release" ]; then
            release_mbid=$(echo "$first_release" | jq -r '.id // empty')
            album_name=$(echo "$first_release" | jq -r '.title // empty')
            release_group_mbid=$(echo "$first_release" | jq -r '.["release-group"].id // empty')
            
            # Try to get track number
            local media=$(echo "$first_release" | jq -r '.media[0] // empty')
            if [ ! -z "$media" ]; then
                disc_number=$(echo "$media" | jq -r '.position // empty')
                local tracks=$(echo "$media" | jq -r '.tracks // empty')
                if [ ! -z "$tracks" ] && [ "$tracks" != "null" ]; then
                    track_number=$(echo "$tracks" | jq -r '.[0].number // empty')
                fi
            fi
        fi
        
        # Get rating
        recording_rating=$(echo "$recording_json" | jq -r '.rating.value // empty')
        recording_votes=$(echo "$recording_json" | jq -r '.rating.votes // empty')
        
        # Extract tags
        local tags_list=$(echo "$recording_json" | jq -r '.tags[]? | .name')
        while IFS= read -r tag; do
            [ -z "$tag" ] && continue
            if [[ "$tag" == bpm:* ]]; then
                bpm=$(echo "$tag" | sed 's/bpm://')
            elif [[ "$tag" == key:* ]]; then
                musical_key=$(echo "$tag" | sed 's/key://')
            elif [[ "$tag" == mood:* ]]; then
                moods="$moods"$'\n'"$(echo "$tag" | sed 's/mood://')"
            elif [[ "$tag" == style:* ]]; then
                styles="$styles"$'\n'"$(echo "$tag" | sed 's/style://')"
            fi
        done <<< "$tags_list"
        
        # Get genres
        genres=$(echo "$recording_json" | jq -r '.genres[]?.name')
        
        # Get work info if available
        if [ ! -z "$work_mbid" ]; then
            local work_json=$(GetWorkInfo "$work_mbid")
            if [ ! -z "$work_json" ]; then
                composer=$(echo "$work_json" | jq -r '.["artist-rels"][]? | select(.type == "composer") | .artist.name' | head -1)
                lyricist=$(echo "$work_json" | jq -r '.["artist-rels"][]? | select(.type == "lyricist") | .artist.name' | head -1)
            fi
        fi
        
        # Get producer and engineer from artist-rels
        producer=$(echo "$recording_json" | jq -r '.["artist-rels"][]? | select(.type == "producer") | .artist.name' | head -1)
        engineer=$(echo "$recording_json" | jq -r '.["artist-rels"][]? | select(.type == "engineer") | .artist.name' | head -1)
        
        log "$artist :: Found MusicBrainz recording: $recording_mbid"
        [ ! -z "$album_name" ] && log "$artist :: Album: $album_name"
        [ ! -z "$isrc" ] && log "$artist :: ISRC: $isrc"
        [ ! -z "$bpm" ] && log "$artist :: BPM: $bpm"
        [ ! -z "$musical_key" ] && log "$artist :: Key: $musical_key"
    else
        log "$artist :: No MusicBrainz match found for: $base_song_title"
    fi
    
    # Get Lidarr artist genres
    local artistGenres=""
    local OLDIFS="$IFS"
    IFS=$'\n'
    artistGenres=($(echo "$artist_data" | jq -r ".genres[]" 2>/dev/null))
    IFS="$OLDIFS"
    
    # Start building NFO
    {
        echo "<musicvideo>"
        
        # Core metadata
        echo "  <title>$title</title>"
        echo "  <artist>$artist</artist>"
        echo "  <year>$year</year>"
        [ ! -z "$formatted_date" ] && echo "  <premiered>$formatted_date</premiered>"
        [ ! -z "$formatted_date" ] && echo "  <releasedate>$formatted_date</releasedate>"
        
        # MusicBrainz IDs
        echo "  <musicbrainzartistid>$artist_mbid</musicbrainzartistid>"
        [ ! -z "$recording_mbid" ] && echo "  <musicbrainzrecordingid>$recording_mbid</musicbrainzrecordingid>"
        [ ! -z "$work_mbid" ] && echo "  <musicbrainzworkid>$work_mbid</musicbrainzworkid>"
        [ ! -z "$release_group_mbid" ] && echo "  <musicbrainzreleasegroupid>$release_group_mbid</musicbrainzreleasegroupid>"
        [ ! -z "$release_mbid" ] && echo "  <musicbrainzalbumid>$release_mbid</musicbrainzalbumid>"
        
        # Album info
        [ ! -z "$album_name" ] && echo "  <album>$album_name</album>"
        echo "  <albumartist>$artist</albumartist>"
        [ ! -z "$track_number" ] && echo "  <track>$track_number</track>"
        [ ! -z "$disc_number" ] && echo "  <disc>$disc_number</disc>"
        
        # ISRC
        [ ! -z "$isrc" ] && echo "  <isrc>$isrc</isrc>"
        
        # Composers, lyricists, producers
        [ ! -z "$composer" ] && echo "  <composer>$composer</composer>"
        [ ! -z "$lyricist" ] && echo "  <lyricist>$lyricist</lyricist>"
        [ ! -z "$producer" ] && echo "  <producer>$producer</producer>"
        [ ! -z "$engineer" ] && echo "  <engineer>$engineer</engineer>"
        
        # Genres (from Lidarr and MusicBrainz)
        if [ ! -z "$artistGenres" ]; then
            for genre_item in "${artistGenres[@]}"; do
                [ ! -z "$genre_item" ] && echo "  <genre>$genre_item</genre>"
            done
        fi
        
        if [ ! -z "$genres" ]; then
            while IFS= read -r genre_item; do
                [ ! -z "$genre_item" ] && echo "  <genre>$genre_item</genre>"
            done <<< "$genres"
        fi
        
        # Styles
        if [ ! -z "$styles" ]; then
            while IFS= read -r style_item; do
                [ ! -z "$style_item" ] && echo "  <style>$style_item</style>"
            done <<< "$styles"
        fi
        
        # Moods
        if [ ! -z "$moods" ]; then
            while IFS= read -r mood_item; do
                [ ! -z "$mood_item" ] && echo "  <mood>$mood_item</mood>"
            done <<< "$moods"
        fi
        
        # YouTube tags as additional metadata
        if [ ! -z "$tags" ]; then
            while IFS= read -r tag_item; do
                [ ! -z "$tag_item" ] && echo "  <tag>$tag_item</tag>"
            done <<< "$tags"
        fi
        
        # Technical metadata
        [ ! -z "$bpm" ] && echo "  <bpm>$bpm</bpm>"
        [ ! -z "$musical_key" ] && echo "  <key>$musical_key</key>"
        [ ! -z "$duration" ] && echo "  <duration>$duration</duration>"
        
        # MusicBrainz ratings
        [ ! -z "$recording_rating" ] && echo "  <rating>$recording_rating</rating>"
        [ ! -z "$recording_votes" ] && echo "  <votes>$recording_votes</votes>"
        
        # Video statistics with timestamp
        [ ! -z "$views" ] && echo "  <views>$views</views>"
        [ ! -z "$likes" ] && echo "  <likes>$likes</likes>"
        echo "  <lastupdated>$current_time</lastupdated>"
        
        # Channel info
        [ ! -z "$channel" ] && echo "  <channel>$channel</channel>"
        [ ! -z "$channel_id" ] && echo "  <channel_id>$channel_id</channel_id>"
        
        # Featured artists as actors
        if [ ! -z "$featured_artists" ]; then
            local order=1
            # Split by commas, &, and, etc.
            echo "$featured_artists" | sed 's/[,&]/\n/g' | sed 's/ and /\n/g' | while IFS= read -r feat_artist; do
                feat_artist=$(echo "$feat_artist" | sed 's/^[[:space:]]*//' | sed 's/[[:space:]]*$//')
                [ ! -z "$feat_artist" ] && [ "$feat_artist" != "$artist" ] && echo "  <actor>"
                [ ! -z "$feat_artist" ] && [ "$feat_artist" != "$artist" ] && echo "    <name>$feat_artist</name>"
                [ ! -z "$feat_artist" ] && [ "$feat_artist" != "$artist" ] && echo "    <role>Featured Artist</role>"
                [ ! -z "$feat_artist" ] && [ "$feat_artist" != "$artist" ] && echo "    <order>$order</order>"
                [ ! -z "$feat_artist" ] && [ "$feat_artist" != "$artist" ] && echo "  </actor>"
                order=$((order + 1))
            done
        fi
        
        # Source info
        echo "  <source>$source</source>"
        echo "  <source_url>https://www.youtube.com/watch?v=$video_id</source_url>"
        echo "  <uniqueid type=\"YouTube\">$video_id</uniqueid>"
        [ ! -z "$recording_mbid" ] && echo "  <uniqueid type=\"MusicBrainz\">$recording_mbid</uniqueid>"
        
        # Description
        local description="$title by $artist"
        [ ! -z "$album_name" ] && description="$description from the album $album_name"
        [ ! -z "$year" ] && description="$description released in $year"
        [ ! -z "$featured_artists" ] && description="$description featuring $featured_artists"
        echo "  <plot>$description</plot>"
        echo "  <outline>Music video</outline>"
        [ ! -z "$album_name" ] && echo "  <tagline>From the album $album_name</tagline>"
        
        # Thumbnail
        echo "  <thumb>${plex_filename}.jpg</thumb>"
        
        echo "</musicvideo>"
    } > "$nfo"
    
    # Format XML
    if command -v tidy &>/dev/null; then
        tidy -w 2000 -i -m -xml "$nfo" &>/dev/null
    fi
    chmod 666 "$nfo"
    
    # Count actual fields
    local field_count=$(grep -c "<[a-z]" "$nfo" 2>/dev/null || echo "0")
    if [ "$is_update" = "true" ]; then
        log "$artist :: ✅ NFO upgraded with $field_count metadata fields"
    else
        log "$artist :: NFO created with $field_count metadata fields"
    fi
}

# Download thumbnail
DownloadThumb() {
    local artist_folder="$1"
    local plex_filename="$2"
    local video_id="$3"
    
    local thumb_file="$videoPath/$artist_folder/${plex_filename}.jpg"
    
    if [ -f "$thumb_file" ]; then
        return
    fi
    
    curl -s "https://img.youtube.com/vi/$video_id/maxresdefault.jpg" -o "$thumb_file" 2>/dev/null
    
    if [ ! -f "$thumb_file" ] || [ ! -s "$thumb_file" ]; then
        curl -s "https://img.youtube.com/vi/$video_id/hqdefault.jpg" -o "$thumb_file" 2>/dev/null
    fi
    
    if [ -f "$thumb_file" ] && [ -s "$thumb_file" ]; then
        chmod 666 "$thumb_file"
    else
        rm -f "$thumb_file" 2>/dev/null
    fi
}

# Force MKV format in download - NO JSON FILES
DownloadVideo() {
    local url="$1"
    local filename="$2"
    
    if [ -d "$videoDownloadPath/incomplete" ]; then
        rm -rf "$videoDownloadPath/incomplete"
    fi

    if [ ! -d "$videoDownloadPath/incomplete" ]; then
        mkdir -p "$videoDownloadPath/incomplete"
        chmod 777 "$videoDownloadPath/incomplete"
    fi

    # Force MKV format with best quality - NO JSON FILES
    yt-dlp -f "bestvideo[height<=1080]+bestaudio/best[height<=1080]" \
        --merge-output-format mkv \
        --remux-video mkv \
        --no-write-info-json \
        --no-write-description \
        --no-write-thumbnail \
        --no-write-subs \
        -o "$videoDownloadPath/incomplete/${filename}.%(ext)s" \
        --no-mtime \
        --geo-bypass "$url"
    
    if [ -f "$videoDownloadPath/incomplete/${filename}.mkv" ]; then
        chmod 666 "$videoDownloadPath/incomplete/${filename}.mkv"
        downloadFailed=false
    else
        downloadFailed=true
    fi
}

# Scan and upgrade existing NFO files for an artist
UpgradeExistingNFOs() {
    local artist="$1"
    local artist_folder="$2"
    local artist_mbid="$3"
    local artist_data="$4"
    
    if [ ! -d "$videoPath/$artist_folder" ]; then
        return
    fi
    
    log "$artist :: Scanning for NFO files that need attention..."
    
    local upgraded=0
    local stats_updated=0
    local skipped=0
    
    # Find all NFO files in artist folder
    find "$videoPath/$artist_folder" -maxdepth 1 -name "*.nfo" -type f | while read nfo_file; do
        # Check if NFO needs stats update
        if NeedsStatsUpdate "$nfo_file"; then
            # Parse existing NFO to get metadata
            local nfo_data=$(ParseExistingNFO "$nfo_file")
            local existing_title=$(echo "$nfo_data" | cut -d'|' -f1)
            local existing_artist=$(echo "$nfo_data" | cut -d'|' -f2)
            local existing_year=$(echo "$nfo_data" | cut -d'|' -f3)
            local existing_id=$(echo "$nfo_data" | cut -d'|' -f4)
            
            if [ ! -z "$existing_id" ]; then
                # Get base filename without extension
                local base_filename=$(basename "$nfo_file" .nfo)
                
                log "$artist :: Stats outdated for: $existing_title - updating..."
                UpdateYouTubeStats "$artist_folder" "$base_filename" "$existing_id" "$nfo_file"
                stats_updated=$((stats_updated + 1))
            fi
        fi
        
        # Check if NFO is already rich
        if IsRichNFO "$nfo_file"; then
            skipped=$((skipped + 1))
            continue
        fi
        
        # Parse existing NFO to get metadata
        local nfo_data=$(ParseExistingNFO "$nfo_file")
        local existing_title=$(echo "$nfo_data" | cut -d'|' -f1)
        local existing_artist=$(echo "$nfo_data" | cut -d'|' -f2)
        local existing_year=$(echo "$nfo_data" | cut -d'|' -f3)
        local existing_id=$(echo "$nfo_data" | cut -d'|' -f4)
        
        # Skip if we can't identify the video
        if [ -z "$existing_id" ]; then
            log "$artist :: Cannot upgrade $(basename "$nfo_file") - missing YouTube ID"
            continue
        fi
        
        # Get base filename without extension
        local base_filename=$(basename "$nfo_file" .nfo)
        local video_file=""
        
        # Find corresponding video file
        if [ -f "$videoPath/$artist_folder/$base_filename.mkv" ]; then
            video_file="$base_filename.mkv"
        elif [ -f "$videoPath/$artist_folder/$base_filename.mp4" ]; then
            video_file="$base_filename.mp4"
        else
            log "$artist :: Cannot upgrade $(basename "$nfo_file") - missing video file"
            continue
        fi
        
        log "$artist :: Upgrading NFO for: $existing_title"
        
        # Clean titles for better matching
        local song_title=$(CleanTitle "$existing_title" "$artist")
        local base_song_title=$(ExtractBaseSongTitle "$song_title")
        
        # Recreate rich NFO
        CreateRichNFO "$artist_folder" "$base_filename" "$existing_title" "$artist" "$artist_mbid" "$existing_year" "$artist_data" "youtube" "$existing_id" "$song_title" "$base_song_title" "true"
        
        upgraded=$((upgraded + 1))
    done
    
    if [ $upgraded -gt 0 ] || [ $stats_updated -gt 0 ]; then
        log "$artist :: ✅ Upgraded $upgraded NFO files, updated stats for $stats_updated videos"
    fi
}

# YouTube Direct Search with strict artist filtering
SearchYouTubeDirect() {
    local artist="$1"
    local artist_folder="$2"
    local artist_mbid="$3"
    local artist_data="$4"
    
    log "$artist :: Searching YouTube..."
    
    # First, upgrade any existing NFO files
    UpgradeExistingNFOs "$artist" "$artist_folder" "$artist_mbid" "$artist_data"
    
    local temp_processed="/tmp/processed_${artist_mbid}.txt"
    > "$temp_processed"
    
    # More specific search - include channel info for verification
    local yt_search_results=$(yt-dlp "ytsearch40:${artist} official music video OR ${artist} - Topic" \
        --print "%(title)s|%(id)s|%(upload_date)s|%(view_count)s|%(channel)s" \
        --no-warnings 2>/dev/null | head -40)
    
    if [ -n "$yt_search_results" ]; then
        # Sort by view count (highest first)
        local total_found=$(echo "$yt_search_results" | wc -l)
        local filtered=0
        local existing=0
        local downloaded=0
        
        # Process results line by line
        while IFS='|' read title id date views channel; do
            # Skip empty lines
            [ -z "$title" ] && continue
            
            local year="${date:0:4}"
            
            # Skip if already processed
            if grep -q "^$id$" "$temp_processed"; then
                continue
            fi
            
            # STRICT artist verification
            local title_lower=$(echo "$title" | tr '[:upper:]' '[:lower:]')
            local artist_lower=$(echo "$artist" | tr '[:upper:]' '[:lower:]')
            local channel_lower=$(echo "$channel" | tr '[:upper:]' '[:lower:]')
            
            # Skip if artist name NOT in title AND NOT in channel
            if [[ "$title_lower" != *"$artist_lower"* ]] && [[ "$channel_lower" != *"$artist_lower"* ]] && [[ "$channel_lower" != *"${artist_lower}vevo"* ]]; then
                filtered=$((filtered + 1))
                continue
            fi
            
            # Skip lyric/audio videos
            if echo "$title" | grep -i -E "(lyric|lyrics|audio|interview|trailer|teaser|behind the scenes|making of|official audio|visualizer)" >/dev/null; then
                filtered=$((filtered + 1))
                continue
            fi
            
            # Skip if title is too short or looks like a compilation
            if [ ${#title} -lt 5 ] || echo "$title" | grep -i -E "(full album|playlist|mix|megamix|compilation)" >/dev/null; then
                filtered=$((filtered + 1))
                continue
            fi
            
            local video_type=$(GetVideoType "$title")
            local song_title=$(CleanTitle "$title" "$artist")
            local base_song_title=$(ExtractBaseSongTitle "$song_title")
            local plex_filename="${song_title}${video_type}"
            local videoDownloadUrl="https://www.youtube.com/watch?v=$id"
            
            if [[ ! "$videoDownloadUrl" =~ watch\?v=[a-zA-Z0-9_-]{11}$ ]]; then
                continue
            fi
            
            echo "$id" >> "$temp_processed"
            
            # Check by video ID in NFO files
            local id_found=false
            if [ -d "$videoPath/$artist_folder" ]; then
                if grep -q "$id" "$videoPath/$artist_folder"/*.nfo 2>/dev/null; then
                    log "$artist :: Already have video with ID: $id"
                    id_found=true
                    existing=$((existing + 1))
                    
                    # Check if stats need update
                    local nfo_file=$(grep -l "$id" "$videoPath/$artist_folder"/*.nfo | head -1)
                    if [ ! -z "$nfo_file" ] && NeedsStatsUpdate "$nfo_file"; then
                        log "$artist :: Stats outdated for existing video, updating..."
                        local base_filename=$(basename "$nfo_file" .nfo)
                        UpdateYouTubeStats "$artist_folder" "$base_filename" "$id" "$nfo_file"
                    fi
                fi
            fi
            
            if [ "$id_found" = true ]; then
                continue
            fi
            
            # Check for existing video files with exact name
            if [ -f "$videoPath/$artist_folder/${plex_filename}.mkv" ]; then
                log "$artist :: Already have: ${plex_filename}.mkv"
                
                if [ ! -f "$videoPath/$artist_folder/${plex_filename}.nfo" ]; then
                    log "$artist :: Creating missing NFO"
                    CreateRichNFO "$artist_folder" "$plex_filename" "$title" "$artist" "$artist_mbid" "$year" "$artist_data" "youtube" "$id" "$song_title" "$base_song_title"
                elif ! IsRichNFO "$videoPath/$artist_folder/${plex_filename}.nfo"; then
                    log "$artist :: Upgrading poor NFO"
                    CreateRichNFO "$artist_folder" "$plex_filename" "$title" "$artist" "$artist_mbid" "$year" "$artist_data" "youtube" "$id" "$song_title" "$base_song_title" "true"
                elif NeedsStatsUpdate "$videoPath/$artist_folder/${plex_filename}.nfo"; then
                    log "$artist :: Stats outdated, updating..."
                    UpdateYouTubeStats "$artist_folder" "$plex_filename" "$id" "$videoPath/$artist_folder/${plex_filename}.nfo"
                fi
                
                if [ ! -f "$videoPath/$artist_folder/${plex_filename}.jpg" ]; then
                    DownloadThumb "$artist_folder" "$plex_filename" "$id"
                fi
                
                existing=$((existing + 1))
                continue
            fi
            
            log "$artist :: Downloading: $title -> ${plex_filename}.mkv"
            downloaded=$((downloaded + 1))
            
            DownloadVideo "$videoDownloadUrl" "$plex_filename"
            
            if [ "$downloadFailed" = "true" ]; then
                log "$artist :: Download failed"
                rm -rf "$videoDownloadPath/incomplete"/*
                downloaded=$((downloaded - 1))
                continue
            fi
            
            if [ ! -d "$videoPath/$artist_folder" ]; then
                mkdir -p "$videoPath/$artist_folder"
                chmod 777 "$videoPath/$artist_folder"
            fi
            
            mv $videoDownloadPath/incomplete/* "$videoPath/$artist_folder"/ 2>/dev/null
            
            local final_file=$(find "$videoPath/$artist_folder" -maxdepth 1 -name "${plex_filename}.mkv" -type f | head -1)
            
            if [ -n "$final_file" ]; then
                log "$artist :: ✅ Downloaded: $(basename "$final_file")"
            fi
            
            CreateRichNFO "$artist_folder" "$plex_filename" "$title" "$artist" "$artist_mbid" "$year" "$artist_data" "youtube" "$id" "$song_title" "$base_song_title"
            DownloadThumb "$artist_folder" "$plex_filename" "$id"
            
            rm -rf "$videoDownloadPath/incomplete" 2>/dev/null
            sleep 2
        done <<< "$(echo "$yt_search_results" | sort -t'|' -k4 -rn)"
        
        log "$artist :: Found $total_found videos, filtered $filtered (wrong artist/type), $existing existing, $downloaded downloaded"
    else
        log "$artist :: No videos found"
    fi
    
    rm -f "$temp_processed"
}

# Main processing loop
VideoProcess() {
    log "Starting video download process"
    
    # Use API key from extended.conf
    LIDARR_API_KEY="$LidarrApiKey"
    
    if [ -z "$videoDownloadTag" ]; then
        lidarrArtists=$(curl -s "http://localhost:8686/api/v1/artist?apikey=$LIDARR_API_KEY" | jq -r .[])
        lidarrArtistIds=$(echo "$lidarrArtists" | jq -r .id)
    else
        lidarrArtists=$(curl -s "http://localhost:8686/api/v1/tag/detail?apikey=$LIDARR_API_KEY" | jq -r -M ".[] | select(.label == \"$videoDownloadTag\") | .artistIds")
        lidarrArtistIds=$(echo "$lidarrArtists" | jq -r .[])
    fi
    
    lidarrArtistIdsCount=$(echo "$lidarrArtistIds" | wc -l)
    processCount=0
    
    for lidarrArtistId in $(echo $lidarrArtistIds); do
        processCount=$((processCount + 1))
        lidarrArtistData=$(curl -s "http://localhost:8686/api/v1/artist/$lidarrArtistId?apikey=$LIDARR_API_KEY")
        lidarrArtistName=$(echo "$lidarrArtistData" | jq -r .artistName)
        lidarrArtistMusicbrainzId=$(echo "$lidarrArtistData" | jq -r .foreignArtistId)
        
        if [ "$lidarrArtistName" == "Various Artists" ]; then
            log "[$processCount/$lidarrArtistIdsCount] $lidarrArtistName :: Skipping"
            continue
        fi
        
        lidarrArtistPath="$(echo "$lidarrArtistData" | jq -r ".path")"
        lidarrArtistFolder="$(basename "$lidarrArtistPath")"
        lidarrArtistFolderNoDisambig="$(echo "$lidarrArtistFolder" | sed "s/ (.*)$//g" | sed "s/\.$//g")"
        
        log "[$processCount/$lidarrArtistIdsCount] Processing: $lidarrArtistName"
        
        SearchYouTubeDirect "$lidarrArtistName" "$lidarrArtistFolderNoDisambig" "$lidarrArtistMusicbrainzId" "$lidarrArtistData"
    done
    
    log "Video download process complete"
}

# Configuration
if [ -z "$videoContainer" ]; then
    videoContainer="mkv"
fi

if [ -z "$downloadPath" ]; then
    downloadPath="/config/downloads"
fi

if [ -z "$videoScriptInterval" ]; then
    videoScriptInterval="15m"
fi

if [ -z "$videoPath" ]; then
    log "ERROR: videoPath not configured"
    exit 1
fi

videoDownloadPath="$downloadPath/videos"
ytdlpConfigurableArgs=""

if [ -f "/config/cookies.txt" ]; then
    ytdlpConfigurableArgs="$ytdlpConfigurableArgs --cookies /config/cookies.txt"
fi

log "Video Downloader v$scriptVersion"
log "Video path: $videoPath"
log "Container format: $videoContainer"
log "Rich NFO metadata enabled - will upgrade existing NFO files"
log "Stats update interval: 7 days"
log "Rich NFO requires: ${RICH_NFO_REQUIRED_FIELDS[*]}"

# Main loop
while true; do
    VideoProcess
    log "Sleeping for $videoScriptInterval..."
    sleep $videoScriptInterval
done

exit
