#!/usr/bin/with-contenv bash
# ==============================================================================
# Video Download Script for Lidarr
# ==============================================================================
# Author: Curtis Freeman
# GitHub: https://github.com/fireishott/arr-scripts_Video
# Version: 4.7
#
# This script downloads official music videos from YouTube and creates
# properly formatted metadata for Plex/Jellyfin/Emby.
# ==============================================================================

scriptVersion="4.7"
scriptName="Video"

# Extended script for Lidarr - YouTube Music Video Downloader
# Source the extended config

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/extended.conf" 2>/dev/null || source "/config/extended.conf"

# Log function
log() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $1" >> "$SCRIPT_DIR/video-download.log"
    echo "$1"
}

# Get artist and track info from Lidarr environment variables
artist_name="$lidarr_artist_name"
artist_mbid="$lidarr_artist_mbid"
track_title="$lidarr_track_title"
track_mbid="$lidarr_track_mbid"
album_title="$lidarr_album_title"
album_mbid="$lidarr_album_mbid"

# Check if this is a full scan or single import
if [ -z "$artist_name" ] || [ -z "$track_title" ]; then
    # Full scan mode
    log "========================================="
    log "Starting periodic scan (interval: $videoScriptInterval)"
    log "Rate limit: $ytdlpRateLimit seconds between searches"
    
    # Get list of artists from Lidarr API
    artists=$(curl -s -H "X-Api-Key: $LidarrApiKey" "$LidarrUrl/api/v1/artist")
    artist_count=$(echo "$artists" | jq '. | length')
    
    log "Found $artist_count total artists in Lidarr"
    
    # If recentScanDays is set, only get recently added artists
    if [ "$recentScanDays" -gt 0 ]; then
        cutoff_date=$(date -d "-$recentScanDays days" +%s)
        filtered_artists=$(echo "$artists" | jq "[.[] | select(.added | fromdateiso8601 >= $cutoff_date)]")
        filtered_count=$(echo "$filtered_artists" | jq '. | length')
        log "Recently added (last $recentScanDays days): $filtered_count artists"
        artists="$filtered_artists"
        artist_count="$filtered_count"
    fi
    
    # Limit number of artists per scan
    if [ "$artist_count" -gt "$maxArtistsPerScan" ]; then
        log "Limiting scan to $maxArtistsPerScan artists (out of $artist_count)"
        artists=$(echo "$artists" | jq ".[0:$maxArtistsPerScan]")
        artist_count="$maxArtistsPerScan"
    fi
    
    log "Processing $artist_count artists in this scan"
    
    processed=0
    for artist in $(echo "$artists" | jq -r '.[] | @base64'); do
        _jq() {
            echo "$artist" | base64 --decode | jq -r "$1"
        }
        
        artist_name=$(_jq '.artistName')
        artist_mbid=$(_jq '.foreignArtistId')
        
        processed=$((processed + 1))
        log "[$processed/$artist_count] Processing: $artist_name"
        
        # Get albums for this artist
        albums=$(curl -s -H "X-Api-Key: $LidarrApiKey" "$LidarrUrl/api/v1/album?artistId=$(_jq '.id')")
        album_count=$(echo "$albums" | jq '. | length')
        
        log "  Found $album_count albums"
        
        track_count=0
        for album in $(echo "$albums" | jq -r '.[] | @base64'); do
            _jq_album() {
                echo "$album" | base64 --decode | jq -r "$1"
            }
            
            album_id=$(_jq_album '.id')
            album_title=$(_jq_album '.title')
            
            # Get tracks for this album
            tracks=$(curl -s -H "X-Api-Key: $LidarrApiKey" "$LidarrUrl/api/v1/track?albumId=$album_id")
            tracks_in_album=$(echo "$tracks" | jq '. | length')
            track_count=$((track_count + tracks_in_album))
        done
        
        # Count existing videos
        safe_artist=$(echo "$artist_name" | sed 's/[\/:*?"<>|]/-/g')
        video_dir="$videoPath/$safe_artist"
        if [ -d "$video_dir" ]; then
            existing_videos=$(find "$video_dir" -type f \( -name "*.mp4" -o -name "*.mkv" -o -name "*.webm" \) | wc -l)
            log "  Tracks: $track_count | Existing videos: $existing_videos | Coverage: $((existing_videos * 100 / track_count))%"
        else
            log "  Tracks: $track_count | Existing videos: 0 | Coverage: 0%"
        fi
        
        # Rate limiting between artists
        if [ $processed -lt $artist_count ]; then
            log "  Waiting $ytdlpRateLimit seconds before next artist..."
            sleep "$ytdlpRateLimit"
        fi
    done
    
    log "Periodic scan complete. Processed $processed artists"
    log "========================================="
    exit 0
fi

# Single import mode (triggered by Lidarr)
log "========================================="
log "Import triggered for: $artist_name - $track_title"
log "Artist MBID: $artist_mbid"
log "Track MBID: $track_mbid"

# Use paths from config
DOWNLOAD_PATH="${downloadPath:-/config/extended/downloads}"
VIDEO_PATH="${videoPath:-/mnt/musicvideos}"
VIDEO_CONTAINER="${videoContainer:-mkv}"
VIDEO_FORMAT="${videoFormat:-bv[height<=1080]/bv[height<=720]/bv+ba}"
VIDEO_NAMING_STYLE="${videoNamingStyle:-standard}"
EMBED_METADATA="${embedMetadata:-true}"
EMBED_THUMBNAILS="${embedThumbnails:-true}"
MIN_HEIGHT="${minimumVideoHeight:-360}"
ATTEMPTS="${videoDownloadAttempts:-3}"
CONCURRENT="${videoConcurrentDownloads:-1}"
YTDLP_EXTRA="${ytdlpExtraArgs:---no-mtime --geo-bypass --sleep-interval 5}"
YTDLP_CACHE="${ytdlpCacheDir:-/config/extended/cache/ytdlp}"
YTDLP_RATE_LIMIT="${ytdlpRateLimit:-10}"
YOUTUBE_FALLBACK="${youtubeFallback:-true}"
CREATE_NFO="${createNfoFiles:-true}"
CREATE_JPG="${createJpgThumbnails:-true}"

# Create necessary directories
mkdir -p "$DOWNLOAD_PATH"
mkdir -p "$YTDLP_CACHE"
mkdir -p "$VIDEO_PATH"

# Clean filenames for filesystem
safe_artist=$(echo "$artist_name" | sed 's/[\/:*?"<>|]/-/g')
safe_track=$(echo "$track_title" | sed 's/[\/:*?"<>|]/-/g')

# Determine naming style for videos
case "$VIDEO_NAMING_STYLE" in
    plex)
        video_filename="$safe_track-video.$VIDEO_CONTAINER"
        nfo_filename="$safe_track-video.nfo"
        jpg_filename="$safe_track-video.jpg"
        ;;
    kodi|emby)
        video_filename="$safe_artist - $safe_track-$VIDEO_CONTAINER.$VIDEO_CONTAINER"
        nfo_filename="$safe_artist - $safe_track-$VIDEO_CONTAINER.nfo"
        jpg_filename="$safe_artist - $safe_track-$VIDEO_CONTAINER.jpg"
        ;;
    standard)
        video_filename="$safe_artist - $safe_track.$VIDEO_CONTAINER"
        nfo_filename="$safe_artist - $safe_track.nfo"
        jpg_filename="$safe_artist - $safe_track.jpg"
        ;;
esac

# Create artist directory
artist_dir="$VIDEO_PATH/$safe_artist"
mkdir -p "$artist_dir"
chmod "$videoFolderPermissions" "$artist_dir" 2>/dev/null || chmod 755 "$artist_dir"

# Check if video already exists
if [ -f "$artist_dir/$video_filename" ]; then
    log "✅ Video already exists: $video_filename"
    exit 0
fi

# ============================================================================
# ARTIST NFO AND ARTWORK - Check if they exist, create if not
# ============================================================================

artist_nfo="$artist_dir/artist.nfo"
artist_jpg="$artist_dir/artist.jpg"
artist_fanart="$artist_dir/fanart.jpg"
artist_clearlogo="$artist_dir/clearlogo.png"
artist_banner="$artist_dir/banner.jpg"
artist_poster="$artist_dir/poster.jpg"

# Create artist.nfo if it doesn't exist
if [ ! -f "$artist_nfo" ]; then
    log "Creating artist.nfo for $artist_name"
    cat > "$artist_nfo" << NFO_EOF
<?xml version="1.0" encoding="utf-8" standalone="yes"?>
<artist>
    <name>$artist_name</name>
    <musicbrainzartistid>$artist_mbid</musicbrainzartistid>
    <genre>Various</genre>
    <style>Various</style>
    <mood>Various</mood>
    <born></born>
    <formed></formed>
    <description></description>
    <biography></biography>
    <disbanded></disbanded>
    <died></died>
</artist>
NFO_EOF
    chmod 644 "$artist_nfo"
    log "✅ Created artist.nfo"
fi

# Try to fetch artist artwork from Fanart.tv if we have MBID and API key
if [ -n "$artist_mbid" ] && [ -n "$FANART_API_KEY" ]; then
    log "Fetching artist artwork from Fanart.tv..."
    
    # Fanart.tv API call
    fanart_url="https://webservice.fanart.tv/v3/music/$artist_mbid?api_key=$FANART_API_KEY"
    
    # Download fanart if not exists
    if [ ! -f "$artist_fanart" ]; then
        fanart_img=$(curl -s "$fanart_url" | jq -r '.artistbackground[0].url' 2>/dev/null)
        if [ -n "$fanart_img" ] && [ "$fanart_img" != "null" ]; then
            curl -s "$fanart_img" -o "$artist_fanart"
            chmod 644 "$artist_fanart"
            log "✅ Downloaded fanart.jpg"
            sleep 1  # Rate limiting
        fi
    fi
    
    # Download artist thumb if not exists
    if [ ! -f "$artist_jpg" ]; then
        thumb_img=$(curl -s "$fanart_url" | jq -r '.artistthumb[0].url' 2>/dev/null)
        if [ -n "$thumb_img" ] && [ "$thumb_img" != "null" ]; then
            curl -s "$thumb_img" -o "$artist_jpg"
            chmod 644 "$artist_jpg"
            log "✅ Downloaded artist.jpg"
            sleep 1
        fi
    fi
fi

# ============================================================================
# CREATE TEMP DOWNLOAD DIRECTORY
# ============================================================================
temp_dir="$DOWNLOAD_PATH/$safe_artist-$safe_track-$$"
mkdir -p "$temp_dir"
cd "$temp_dir"

# Build search query
search_query="$artist_name $track_title official music video"
log "Searching YouTube for: $search_query"

# Build yt-dlp command with rate limiting
ytdlp_cmd="yt-dlp \
    --quiet \
    --no-warnings \
    --default-search \"ytsearch1\" \
    --format \"$VIDEO_FORMAT\" \
    --output \"$temp_dir/%(title)s.%(ext)s\" \
    --write-thumbnail \
    --write-info-json \
    --sleep-requests $YTDLP_RATE_LIMIT \
    --sleep-interval 5 \
    --max-sleep-interval 10 \
    --user-agent \"Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36\" \
    --cache-dir \"$YTDLP_CACHE\" \
    --limit-rate 5M \
    $YTDLP_EXTRA"

# Add cookies if they exist
if [ -f "$youtubeCookiesFile" ]; then
    ytdlp_cmd="$ytdlp_cmd --cookies \"$youtubeCookiesFile\""
fi

# Add subtitles if enabled
if [ "$embedSubtitles" = "true" ] && [ -n "$subtitleLanguages" ]; then
    ytdlp_cmd="$ytdlp_cmd --write-subs --sub-langs $subtitleLanguages --embed-subs"
fi

# Execute download
attempt=1
while [ $attempt -le $ATTEMPTS ]; do
    log "Download attempt $attempt of $ATTEMPTS"
    
    eval "$ytdlp_cmd \"ytsearch1:$search_query\""
    
    if [ $? -eq 0 ]; then
        # Find downloaded file
        downloaded_file=$(find "$temp_dir" -maxdepth 1 -type f \( -name "*.mp4" -o -name "*.mkv" -o -name "*.webm" \) | head -1)
        
        if [ -n "$downloaded_file" ]; then
            # Get file info
            file_ext="${downloaded_file##*.}"
            final_video="$artist_dir/$video_filename"
            final_nfo="$artist_dir/$nfo_filename"
            final_jpg="$artist_dir/$jpg_filename"
            
            # Check resolution
            if [ -n "$MIN_HEIGHT" ] && [ "$MIN_HEIGHT" -gt 0 ]; then
                height=$(ffprobe -v quiet -select_streams v:0 -show_entries stream=height -of default=noprint_wrappers=1:nokey=1 "$downloaded_file" 2>/dev/null)
                if [ -n "$height" ] && [ "$height" -lt "$MIN_HEIGHT" ]; then
                    log "⚠️ Video resolution $height is below minimum $MIN_HEIGHT, skipping"
                    rm -rf "$temp_dir"
                    exit 1
                fi
            fi
            
            # Convert if needed (mkv to mp4, etc.)
            if [ "$VIDEO_CONTAINER" = "mp4" ] && [ "$file_ext" != "mp4" ]; then
                log "Converting to MP4..."
                ffmpeg -i "$downloaded_file" -c copy -movflags +faststart "$temp_dir/converted.mp4"
                if [ $? -eq 0 ]; then
                    mv "$temp_dir/converted.mp4" "$final_video"
                else
                    cp "$downloaded_file" "$final_video"
                fi
            else
                cp "$downloaded_file" "$final_video"
            fi
            
            # Set video permissions
            chmod "$videoFilePermissions" "$final_video" 2>/dev/null || chmod 644 "$final_video"
            log "✅ Video saved: $video_filename"
            
            # Find thumbnail
            thumbnail=$(find "$temp_dir" -maxdepth 1 -name "*.jpg" -o -name "*.webp" | head -1)
            
            # Create video NFO file
            if [ "$CREATE_NFO" = "true" ]; then
                cat > "$final_nfo" << NFO_EOF
<?xml version="1.0" encoding="utf-8"?>
<musicvideo>
    <title>$track_title</title>
    <artist>$artist_name</artist>
    <album>$album_title</album>
    <year>$(date +%Y)</year>
    <genre>Music Video</genre>
    <plot>Official music video for $track_title by $artist_name</plot>
    <musicbrainz_artistid>$artist_mbid</musicbrainz_artistid>
    <musicbrainz_trackid>$track_mbid</musicbrainz_trackid>
    <musicbrainz_albumid>$album_mbid</musicbrainz_albumid>
</musicvideo>
NFO_EOF
                chmod 644 "$final_nfo"
                log "✅ Created NFO: $nfo_filename"
            fi
            
            # Create JPG thumbnail for video
            if [ "$CREATE_JPG" = "true" ] && [ -n "$thumbnail" ]; then
                cp "$thumbnail" "$final_jpg"
                chmod 644 "$final_jpg"
                log "✅ Created JPG: $jpg_filename"
            fi
            
            # Embed thumbnail in video if enabled
            if [ "$EMBED_THUMBNAILS" = "true" ] && [ -n "$thumbnail" ]; then
                ffmpeg -i "$final_video" -i "$thumbnail" -map 0 -map 1 -c copy -disposition:1 attached_pic "$final_video.tmp" 2>/dev/null
                if [ $? -eq 0 ]; then
                    mv "$final_video.tmp" "$final_video"
                    log "✅ Embedded thumbnail in video"
                else
                    rm -f "$final_video.tmp"
                fi
            fi
            
            log "✅ Successfully downloaded: $artist_name - $track_title"
            
            # Cleanup
            rm -rf "$temp_dir"
            
            log "========================================="
            exit 0
        fi
    fi
    
    # Fallback searches if enabled
    if [ "$YOUTUBE_FALLBACK" = "true" ] && [ $attempt -lt $ATTEMPTS ]; then
        case $attempt in
            1)
                search_query="$artist_name $track_title video"
                ;;
            2)
                search_query="$track_title $artist_name"
                ;;
        esac
        log "Fallback attempt $attempt: $search_query"
        sleep "$youtubeFallbackDelay"
    fi
    
    attempt=$((attempt + 1))
done

log "❌ Failed to download after $ATTEMPTS attempts"
rm -rf "$temp_dir"
log "========================================="
exit 1
